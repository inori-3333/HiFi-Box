{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HiFi-Box",
  "version": "0.1.0",
  "identifier": "com.inori.hifibox",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npm run dev\"",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"npm run build\"",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HiFi-Box",
        "width": 1240,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
